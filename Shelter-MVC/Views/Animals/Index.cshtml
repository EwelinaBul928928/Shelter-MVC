@model IEnumerable<Shelter_MVC.Models.Animal>

@{
    ViewData["Title"] = "Zwierzęta";
}

<h1>Zwierzeta do adopcji</h1>

@if (User.IsInRole("Administrator"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Dodaj nowe zwierzę</a>
    </p>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
@foreach (var item in Model) {
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            @if (!string.IsNullOrEmpty(item.PhotoUrl))
            {
                <img src="@item.PhotoUrl" class="card-img-top" alt="@item.Name" style="height: 250px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/300x250?text=Brak+zdjęcia'">
            }
            else
            {
                <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 250px;">
                    <span class="text-muted">Brak zdjęcia</span>
                </div>
            }
            <div class="card-body">
                <h5 class="card-title">@Html.DisplayFor(modelItem => item.Name)</h5>
                <p class="card-text">
                    <strong>Wiek:</strong> @item.Age lat<br/>
                    @if (!string.IsNullOrEmpty(item.Description))
                    {
                        @if (item.Description.Length > 100)
                        {
                            @item.Description.Substring(0, 100) <text>...</text>
                        }
                        else
                        {
                            @item.Description
                        }
                    }
                </p>
                @if (item.IsAdopted)
                {
                    <span class="badge bg-secondary">Zaadoptowany</span>
                }
                else
                {
                    <span class="badge bg-success">Gotowy do adopcji</span>
                }
            </div>
            <div class="card-footer">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm">Szczegóły</a>
                @if (User.IsInRole("Administrator"))
                {
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">Edytuj</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Usuń</a>
                }
                @if (User.Identity.IsAuthenticated && !item.IsAdopted && !User.IsInRole("Administrator"))
                {
                    <a asp-controller="AdoptionApplications" asp-action="Create" asp-route-animalId="@item.Id" class="btn btn-success btn-sm">Złóż wniosek</a>
                }
            </div>
        </div>
    </div>
}
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Brak zwierząt do wyświetlenia.
    </div>
}
