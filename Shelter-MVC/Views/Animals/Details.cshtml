@model Shelter_MVC.Models.Animal

@{
    ViewData["Title"] = Model.Name;
}

<h1>@Html.DisplayFor(model => model.Name)</h1>

<div class="row">
    <div class="col-md-4">
        @if (!string.IsNullOrEmpty(Model.PhotoUrl))
        {
            <img src="@Model.PhotoUrl" class="img-fluid rounded mb-3" alt="@Model.Name" onerror="this.src='https://via.placeholder.com/400x400?text=Brak+zdjęcia'">
        }
        else
        {
            <div class="bg-light d-flex align-items-center justify-content-center rounded mb-3" style="height: 400px;">
                <span class="text-muted">Brak zdjęcia</span>
            </div>
        }
    </div>
    <div class="col-md-8">
        <dl class="row">
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Name)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Name)
            </dd>
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Age)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Age) lat
            </dd>
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Description)
            </dt>
            <dd class="col-sm-9">
                @if (string.IsNullOrEmpty(Model.Description))
                {
                    <span class="text-muted">Brak opisu</span>
                }
                else
                {
                    @Html.DisplayFor(model => model.Description)
                }
            </dd>
            <dt class="col-sm-3">
                Status
            </dt>
            <dd class="col-sm-9">
                @if (Model.IsAdopted)
                {
                    <span class="badge bg-secondary">Zaadoptowany</span>
                }
                else
                {
                    <span class="badge bg-success">Gotowy do adopcji</span>
                }
            </dd>
        </dl>
        
        <div class="mt-4">
            @if (User.Identity.IsAuthenticated && !Model.IsAdopted && !User.IsInRole("Administrator"))
            {
                <a asp-controller="AdoptionApplications" asp-action="Create" asp-route-animalId="@Model.Id" class="btn btn-success btn-lg">Złóż wniosek adopcyjny</a>
            }
            @if (User.IsInRole("Administrator"))
            {
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-secondary">Edytuj</a>
                <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger">Usuń</a>
            }
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-outline-secondary">Powrót do listy</a>
</div>
