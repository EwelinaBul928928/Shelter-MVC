@model IEnumerable<Shelter_MVC.Models.Animal>

@{
    ViewData["Title"] = "Historia zdrowia zwierząt";
}

<h1>Historia zdrowia zwierząt</h1>

@if (User.IsInRole("Administrator"))
{
    <p>
        <a asp-action="CreateRecord" class="btn btn-primary">Dodaj rekord zdrowia</a>
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Species)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Age)
            </th>
            <th>
                Ostatnia wizyta
            </th>
            <th>
                Ostatni zabieg/szczepienie
            </th>
            <th>
                Weterynarz
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        var latestRecord = item.HealthRecords?.OrderByDescending(hr => hr.VisitDate).FirstOrDefault();
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Species.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Age) lat
            </td>
            <td>
                @if (latestRecord != null)
                {
                    @latestRecord.VisitDate.ToString("dd.MM.yyyy")
                }
                else
                {
                    <text>Brak danych</text>
                }
            </td>
            <td>
                @if (latestRecord != null)
                {
                    @Html.DisplayFor(modelItem => latestRecord.Description)
                }
                else
                {
                    <text>-</text>
                }
            </td>
            <td>
                @if (latestRecord != null && !string.IsNullOrEmpty(latestRecord.VetName))
                {
                    @Html.DisplayFor(modelItem => latestRecord.VetName)
                }
                else
                {
                    <text>-</text>
                }
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Zobacz pełną historię</a>
            </td>
        </tr>
}
    </tbody>
</table>
