@model Shelter_MVC.Models.AdoptionApplication
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Złóż wniosek adopcyjny";
    var animalId = ViewContext.RouteData.Values["animalId"]?.ToString() ?? ViewContext.HttpContext.Request.Query["animalId"].ToString();
}

<h1>Złóż wniosek adopcyjny</h1>

@if (ViewBag.Animal != null)
{
    <div class="alert alert-info">
        <strong>Zwierzak:</strong> @ViewBag.Animal.Name
    </div>
}

<hr />
<div class="row">
    <div class="col-md-8">
        <form asp-action="Create">
            <div asp-validation-summary="All" class="text-danger"></div>
            
            @* Pola ApplicationDate, Status i UserId są ustawiane w kontrolerze, nie w formularzu *@
            
            @if (animalId != null && int.TryParse(animalId, out int parsedAnimalId))
            {
                <input type="hidden" asp-for="AnimalId" value="@parsedAnimalId" />
            }
            else
            {
                <div class="form-group mb-3">
                    <label asp-for="AnimalId" class="control-label">Wybierz zwierzę</label>
                    <select asp-for="AnimalId" class="form-control" asp-items="@(ViewData["AnimalId"] as SelectList)">
                        <option value="">-- Wybierz zwierzę --</option>
                    </select>
                    <span asp-validation-for="AnimalId" class="text-danger"></span>
                </div>
            }
            
            <div class="form-group mb-3">
                <label asp-for="Message" class="control-label"></label>
                <textarea asp-for="Message" class="form-control" rows="6" placeholder="Napisz dlaczego chcesz adoptować to zwierzę..."></textarea>
                <span asp-validation-for="Message" class="text-danger"></span>
                <small class="form-text text-muted">Opisz swoją sytuację, doświadczenie z zwierzętami i dlaczego chcesz adoptować to zwierzę.</small>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Wyślij wniosek" class="btn btn-primary btn-lg" />
                <a asp-controller="Animals" asp-action="Index" class="btn btn-secondary">Anuluj</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
