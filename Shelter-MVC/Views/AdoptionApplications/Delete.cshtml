@model Shelter_MVC.Models.AdoptionApplication

@{
    ViewData["Title"] = "Usuń wniosek";
}

<h1>Usuń wniosek adopcyjny</h1>

<h3>Czy na pewno chcesz usunąć ten wniosek?</h3>
<div class="card mt-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">
                Data złożenia
            </dt>
            <dd class="col-sm-9">
                @Model.ApplicationDate.ToString("dd.MM.yyyy HH:mm")
            </dd>
            <dt class="col-sm-3">
                Zwierzę
            </dt>
            <dd class="col-sm-9">
                <strong>@Model.Animal.Name</strong>
            </dd>
            <dt class="col-sm-3">
                Status
            </dt>
            <dd class="col-sm-9">
                @switch (Model.Status)
                {
                    case Shelter_MVC.Models.ApplicationStatus.Oczekujący:
                        <span class="badge bg-warning">Oczekujący</span>
                        break;
                    case Shelter_MVC.Models.ApplicationStatus.Zaakceptowany:
                        <span class="badge bg-success">Zaakceptowany</span>
                        break;
                    case Shelter_MVC.Models.ApplicationStatus.Odrzucony:
                        <span class="badge bg-danger">Odrzucony</span>
                        break;
                    default:
                        <span class="badge bg-secondary">@Model.Status</span>
                        break;
                }
            </dd>
            <dt class="col-sm-3">
                Użytkownik
            </dt>
            <dd class="col-sm-9">
                @Model.UserId
            </dd>
            <dt class="col-sm-3">
                Wiadomość
            </dt>
            <dd class="col-sm-9">
                @if (string.IsNullOrEmpty(Model.Message))
                {
                    <span class="text-muted">Brak wiadomości</span>
                }
                else
                {
                    @if (Model.Message.Length > 100)
                    {
                        @Model.Message.Substring(0, 100) <text>...</text>
                    }
                    else
                    {
                        @Model.Message
                    }
                }
            </dd>
        </dl>
    </div>
</div>
    
<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Usuń" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
</form>
